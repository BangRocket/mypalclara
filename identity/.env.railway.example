# Required
DATABASE_URL=postgresql://user:password@host:5432/database
IDENTITY_JWT_SECRET=replace-with-a-long-random-secret

# Required for browser clients
IDENTITY_CORS_ORIGINS=https://accounts.mypalclara.com,https://mypalclara.com,https://www.mypalclara.com

# Optional but recommended (service-to-service auth)
IDENTITY_SERVICE_SECRET=replace-with-another-long-random-secret

# Optional OAuth providers (enable one or both)
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=https://accounts.mypalclara.com/oauth/callback/discord

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://accounts.mypalclara.com/oauth/callback/google
