2026-01-07 02:50:04 | INFO | """
Memory Manager - Handles persistent memory storage and retrieval
"""

import json
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Any


class MemoryManager:
    """Manages Clara's persistent memory system."""
    
    def __init__(self, data_dir: str):
        self.data_dir = Path(data_dir)
        self.data_dir.mkdir(parents=True, exist_ok=True)
        
        self.memories_file = self.data_dir / "memories.json"
        self.sessions_file = self.data_dir / "sessions.json"
        
        self.memories = self._load_memories()
        self.sessions = self._load_sessions()
        
    def _load_memories(self) -> Dict[str, List[Dict]]:
        """Load memories from disk."""
        if self.memories_file.exists():
            with open(self.memories_file, 'r') as f:
                return json.load(f)
        return {
            "facts": [],
            "preferences": [],
            "experiences": [],
            "relationships": [],
            "context": []
        }
    
    def _load_sessions(self) -> Dict[str, Any]:
        """Load session data from disk."""
        if self.sessions_file.exists():
            with open(self.sessions_file, 'r') as f:
                return json.load(f)
        return {
            "last_session": None,
            "total_sessions": 0,
            "conversation_count": 0
        }
    
    def _save_memories(self):
        """Save memories to disk."""
        with open(self.memories_file, 'w') as f:
            json.dump(self.memories, f, indent=2, default=str)
    
    def _save_sessions(self):
        """Save session data to disk."""
        with open(self.sessions_file, 'w') as f:
            json.dump(self.sessions, f, indent=2, default=str)
    
    def add_memories(self, new_memories: Dict[str, List[str]]):
        """Add new memories to the store."""
        timestamp = datetime.now().isoformat()
        
        for category, items in new_memories.items():
            if category in self.memories and items:
                for item in items:
                    # Check for duplicates (simple string matching)
                    existing = [m["content"] for m in self.memories[category]]
                    if item not in existing:
                        self.memories[category].append({
                            "content": item,
                            "timestamp": timestamp,
                            "access_count": 0
                        })
        
        self._save_memories()
    
    def get_relevant_memories(self, limit: int = 20) -> Dict[str, List[str]]:
        """Get the most relevant memories for context."""
        relevant = {}
        
        for category, memories in self.memories.items():
            # Sort by recency and access count
            sorted_memories = sorted(
                memories,
                key=lambda m: (m.get("access_count", 0), m.get("timestamp", "")),
                reverse=True
            )[:limit // 5]  # Distribute across categories
            
            if sorted_memories:
                relevant[category] = [m["content"] for m in sorted_memories]
                
                # Update access counts
                for m in sorted_memories:
                    m["access_count"] = m.get("access_count", 0) + 1
        
        self._save_memories()
        return relevant
    
    def format_memories_for_prompt(self, memories: Dict[str, List[str]]) -> str:
        """Format memories for inclusion in system prompt."""
        if not any(memories.values()):
            return "You don't have any memories of this person yet. This might be your first conversation."
        
        sections = []
        
        if memories.get("facts"):
            sections.append("What you know about them:\n- " + "\n- ".join(memories["facts"]))
        
        if memories.get("preferences"):
            sections.append("Their preferences:\n- " + "\n- ".join(memories["preferences"]))
            
        if memories.get("experiences"):
            sections.append("Experiences they've shared:\n- " + "\n- ".join(memories["experiences"]))
            
        if memories.get("relationships"):
            sections.append("People in their life:\n- " + "\n- ".join(memories["relationships"]))
            
        if memories.get("context"):
            sections.append("Current context/ongoing situations:\n- " + "\n- ".join(memories["context"]))
        
        return "Your memories of this person:\n\n" + "\n\n".join(sections)
    
    def get_user_name(self) -> Optional[str]:
        """Extract user's name from memories if known."""
        for fact in self.memories.get("facts", []):
            content = fact["content"].lower()
            if "name is" in content or "called" in content or "i'm" in content:
                # Simple extraction - could be improved
                words = fact["content"].split()
                for i, word in enumerate(words):
                    if word.lower() in ["is", "called", "i'm"] and i + 1 < len(words):
                        return words[i + 1].strip(".,!?")
        return None
    
    def get_last_session_time(self) -> Optional[datetime]:
        """Get the timestamp of the last session."""
        if self.sessions.get("last_session"):
            return datetime.fromisoformat(self.sessions["last_session"])
        return None
    
    def load_session(self):
        """Called when a new session starts."""
        self.sessions["total_sessions"] = self.sessions.get("total_sessions", 0) + 1
        self._save_sessions()
    
    def save_session(self, conversation_history: List[Dict]):
        """Save session data when ending."""
        self.sessions["last_session"] = datetime.now().isoformat()
        self.sessions["conversation_count"] = self.sessions.get("conversation_count", 0) + len(conversation_history)
        self._save_sessions()
