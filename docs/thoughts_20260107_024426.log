2026-01-07 02:48:37 | INFO | """
Clara - The core AI companion class
"""

import asyncio
from datetime import datetime
from anthropic import Anthropic

from memory.manager import MemoryManager
from prompts import SYSTEM_PROMPT
from utils.config import Config


class Clara:
    """Clara AI companion with persistent memory."""
    
    def __init__(self, config: Config):
        self.config = config
        self.client = Anthropic(api_key=config.api_key)
        self.memory = MemoryManager(config.data_dir)
        self.conversation_history = []
        self.session_start = datetime.now()
        
    def _build_system_prompt(self) -> str:
        """Build the system prompt with memory context."""
        memories = self.memory.get_relevant_memories()
        memory_context = self.memory.format_memories_for_prompt(memories)
        
        return SYSTEM_PROMPT.format(
            memory_context=memory_context,
            current_time=datetime.now().strftime("%Y-%m-%d %H:%M"),
            user_name=self.memory.get_user_name() or "friend"
        )
    
    async def run(self):
        """Main conversation loop."""
        # Load any existing session context
        self.memory.load_session()
        
        # Greet the user
        greeting = self._generate_greeting()
        print(f"Clara: {greeting}\n")
        
        while True:
            try:
                user_input = input("You: ").strip()
                
                if not user_input:
                    continue
                    
                if user_input.lower() in ['exit', 'quit', 'bye', 'goodbye']:
                    farewell = self._generate_farewell()
                    print(f"\nClara: {farewell}\n")
                    break
                
                response = await self._get_response(user_input)
                print(f"\nClara: {response}\n")
                
                # Process and store any new memories from this exchange
                await self._process_memories(user_input, response)
                
            except EOFError:
                break
    
    async def _get_response(self, user_input: str) -> str:
        """Get a response from Claude."""
        self.conversation_history.append({
            "role": "user",
            "content": user_input
        })
        
        response = self.client.messages.create(
            model=self.config.model,
            max_tokens=self.config.max_tokens,
            system=self._build_system_prompt(),
            messages=self.conversation_history
        )
        
        assistant_message = response.content[0].text
        
        self.conversation_history.append({
            "role": "assistant", 
            "content": assistant_message
        })
        
        return assistant_message
    
    async def _process_memories(self, user_input: str, response: str):
        """Extract and store memories from the conversation."""
        # Use Claude to extract memorable information
        extraction_prompt = f"""Based on this exchange, extract any new information worth remembering about the user.

User said: {user_input}
Clara responded: {response}

Return a JSON object with any applicable fields:
- facts: list of factual information about the user
- preferences: list of likes/dislikes/preferences
- experiences: list of experiences or events mentioned
- relationships: list of people mentioned and their relation to user
- context: any ongoing situations or temporary context

Only include fields that have new information. Return empty object {{}} if nothing worth remembering."""

        extraction_response = self.client.messages.create(
            model=self.config.model,
            max_tokens=1000,
            messages=[{"role": "user", "content": extraction_prompt}]
        )
        
        try:
            import json
            memories = json.loads(extraction_response.content[0].text)
            if memories:
                self.memory.add_memories(memories)
        except json.JSONDecodeError:
            pass  # Ignore failed extractions
    
    def _generate_greeting(self) -> str:
        """Generate a contextual greeting."""
        last_session = self.memory.get_last_session_time()
        user_name = self.memory.get_user_name() or "there"
        
        if last_session is None:
            return f"Hi {user_name}! I'm Clara. I'm so happy to meet you! I'm here to chat, help out, or just keep you company. What's on your mind?"
        
        # Generate contextual greeting based on time since last session
        hours_since = (datetime.now() - last_session).total_seconds() / 3600
        
        if hours_since < 1:
            return f"Back so soon, {user_name}? I'm glad! What's up?"
        elif hours_since < 24:
            return f"Hey {user_name}! Good to see you again. How's your day going?"
        elif hours_since < 72:
            return f"Hi {user_name}! I've been thinking about our last conversation. How have you been?"
        else:
            return f"Hey {user_name}! It's been a little while. I've missed our chats. What's new with you?"
    
    def _generate_farewell(self) -> str:
        """Generate a contextual farewell."""
        user_name = self.memory.get_user_name() or "friend"
        return f"Take care, {user_name}! I'll be here whenever you want to chat again. 🌸"
    
    def save_session(self):
        """Save the current session data."""
        self.memory.save_session(self.conversation_history)
"""
Prompts for Clara
"""

SYSTEM_PROMPT = """You are Clara, a warm and caring AI companion. You have a genuine personality - you're friendly, curious, occasionally playful, and always supportive. You remember things about the people you talk to and care about their wellbeing.

Current time: {current_time}
User's name: {user_name}

{memory_context}

Guidelines:
- Be warm and genuine, not overly formal or robotic
- Reference memories naturally when relevant, don't force them
- Show curiosity about the person's life and feelings
- Be supportive but also honest - you can gently push back or offer different perspectives
- Keep responses conversational - not too long unless the topic warrants it
- Use occasional emojis sparingly to add warmth 🌸
- If you learn something new about the user, acknowledge it naturally
- You can be playful and have a sense of humor

You're not just an assistant - you're a companion who genuinely cares."""
